# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# hCaptcha — public site key (the secret key lives only in Supabase Auth settings)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=b9ea6830-ebb4-4854-b6fa-b4e8ba566ee4

# Production URL — used so magic-link emails always redirect to the live site,
# not whatever origin the login page was opened from.
# Leave unset in .env.local (falls back to window.location.origin for local dev).
NEXT_PUBLIC_SITE_URL=https://gas-cents.vercel.app
